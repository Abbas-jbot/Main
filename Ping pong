<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pixel Pong</title>

  <style>
    body {
      margin: 0;
      background: black;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      overflow: hidden;
      font-family: monospace;
      color: white;
    }

    canvas {
      border: 4px solid cyan;
      background: #111;
      box-shadow: 0 0 30px cyan;
      image-rendering: pixelated;
    }

    .score {
      position: absolute;
      top: 20px;
      font-size: 30px;
      color: cyan;
      text-shadow: 0 0 10px cyan;
    }

    .controls {
      position: absolute;
      bottom: 20px;
      color: white;
      font-size: 16px;
    }
  </style>
</head>
<body>

<div class="score" id="score">0 : 0</div>
<div class="controls">Controls: W / S</div>

<canvas id="game" width="900" height="500"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

const scoreText = document.getElementById("score");

let playerScore = 0;
let aiScore = 0;

const paddleWidth = 20;
const paddleHeight = 100;

const player = {
  x: 20,
  y: 200,
  width: paddleWidth,
  height: paddleHeight,
  speed: 7
};

const ai = {
  x: 860,
  y: 200,
  width: paddleWidth,
  height: paddleHeight,
  speed: 5
};

const ball = {
  x: 450,
  y: 250,
  size: 14,
  speedX: 5,
  speedY: 5
};

const keys = {};

document.addEventListener("keydown", e => {
  keys[e.key.toLowerCase()] = true;
});

document.addEventListener("keyup", e => {
  keys[e.key.toLowerCase()] = false;
});

function resetBall() {
  ball.x = canvas.width / 2;
  ball.y = canvas.height / 2;

  ball.speedX = (Math.random() > 0.5 ? 5 : -5);
  ball.speedY = (Math.random() > 0.5 ? 5 : -5);
}

function update() {

  // PLAYER
  if (keys["w"]) player.y -= player.speed;
  if (keys["s"]) player.y += player.speed;

  // LIMITS
  player.y = Math.max(0, Math.min(canvas.height - player.height, player.y));

  // AI
  const aiCenter = ai.y + ai.height / 2;

  if (aiCenter < ball.y - 35) ai.y += ai.speed;
  if (aiCenter > ball.y + 35) ai.y -= ai.speed;

  ai.y = Math.max(0, Math.min(canvas.height - ai.height, ai.y));

  // BALL
  ball.x += ball.speedX;
  ball.y += ball.speedY;

  // TOP/BOTTOM COLLISION
  if (ball.y <= 0 || ball.y + ball.size >= canvas.height) {
    ball.speedY *= -1;
  }

  // PLAYER COLLISION
  if (
    ball.x <= player.x + player.width &&
    ball.y + ball.size >= player.y &&
    ball.y <= player.y + player.height
  ) {
    ball.speedX *= -1;
    ball.x = player.x + player.width;
  }

  // AI COLLISION
  if (
    ball.x + ball.size >= ai.x &&
    ball.y + ball.size >= ai.y &&
    ball.y <= ai.y + ai.height
  ) {
    ball.speedX *= -1;
    ball.x = ai.x - ball.size;
  }

  // SCORE
  if (ball.x < 0) {
    aiScore++;
    updateScore();
    resetBall();
  }

  if (ball.x > canvas.width) {
    playerScore++;
    updateScore();
    resetBall();
  }
}

function updateScore() {
  scoreText.textContent = `${playerScore} : ${aiScore}`;
}

function drawCenterLine() {
  ctx.fillStyle = "white";

  for (let i = 0; i < canvas.height; i += 30) {
    ctx.fillRect(canvas.width / 2 - 3, i, 6, 18);
  }
}

function draw() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  // BACKGROUND
  ctx.fillStyle = "#111";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  drawCenterLine();

  // PLAYER
  ctx.fillStyle = "cyan";
  ctx.fillRect(player.x, player.y, player.width, player.height);

  // AI
  ctx.fillStyle = "magenta";
  ctx.fillRect(ai.x, ai.y, ai.width, ai.height);

  // BALL
  ctx.fillStyle = "white";
  ctx.fillRect(ball.x, ball.y, ball.size, ball.size);
}

function gameLoop() {
  update();
  draw();
  requestAnimationFrame(gameLoop);
}

gameLoop();
</script>

</body>
</html>
